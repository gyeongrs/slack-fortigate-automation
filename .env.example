# --- FortiGate REST API ---
# Hostname or IP of the FortiGate management interface (no scheme).
FORTIGATE_HOST=fw.example.local
# API admin token (System > Administrators > REST API Admin).
FORTIGATE_API_TOKEN=changeme
# Set to "false" only with a valid TLS cert path; "true" skips verification (lab only).
FORTIGATE_VERIFY_TLS=true
# Optional path to a CA bundle if using a private CA.
FORTIGATE_CA_BUNDLE=
# Optional VDOM (leave empty for single-VDOM devices).
FORTIGATE_VDOM=

# --- Slack ---
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
# Channel where approvals / plan diffs are posted.
SLACK_NOTIFY_CHANNEL=#netops-changes

# --- GitHub (for PR automation from the Slack bot) ---
GITHUB_TOKEN=ghp_...
GITHUB_REPO=your-org/slack-fortigate-automation
GITHUB_BASE_BRANCH=main
